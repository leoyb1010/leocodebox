# Dependencies (anchored + nested)
node_modules/

# Build outputs (regenerated via `npm run build`) — anchored to repo root so
# nested source dirs like scripts/release/ are NOT ignored.
/dist/
/dist-server/

# Packaging / release artifacts (large; DMG etc.) — anchored to repo root.
/release/
/.desktop-build/
*.dmg
*.blockmap

# Local env & secrets
.env
.env.*
*.pem
*.key
*.p12
*.mobileprovision
*.keychain

# Local runtime data
*.log
.DS_Store

# Editor
.vscode/
.idea/

# Local agent/review scratch data
/.review-*
/.claude/settings.local.json
/.claude/worktrees/
