<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron/Chromium JIT and executable memory (required under hardened runtime) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- leocodebox spawns local agent CLIs (claude/codex/cursor/opencode) and a
       bundled node server; these need dyld env vars and library loading -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Child processes inherit the sandbox/runtime -->
  <key>com.apple.security.inherit</key>
  <true/>
</dict>
</plist>
