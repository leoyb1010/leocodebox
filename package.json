{
  "name": "leocodebox",
  "version": "1.49.1",
  "productName": "leocodebox",
  "description": "Local desktop controller for coding agents",
  "type": "module",
  "main": "dist-server/server/index.js",
  "private": true,
  "bin": {
    "leocodebox": "dist-server/server/cli.js"
  },
  "files": [
    "electron/",
    "server/",
    "shared/",
    "public/api-docs.html",
    "dist/",
    "dist-server/",
    "scripts/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "homepage": "https://github.com/leoyb1010/leocodebox",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leoyb1010/leocodebox.git"
  },
  "bugs": {
    "url": "https://github.com/leoyb1010/leocodebox/issues"
  },
  "scripts": {
    "dev": "concurrently --kill-others \"npm run server:dev\" \"npm run client\"",
    "server": "node dist-server/server/index.js",
    "server:dev": "tsx --tsconfig server/tsconfig.json server/index.ts",
    "server:dev-watch": "tsx watch --tsconfig server/tsconfig.json server/index.ts",
    "client": "vite",
    "desktop": "electron electron/main.js",
    "desktop:dev": "cross-env ELECTRON_DEV_URL=http://127.0.0.1:5173 electron electron/main.js",
    "browser:runtime:ensure": "node scripts/release/ensure-browser-runtime.mjs",
    "desktop:stage": "npm run browser:runtime:ensure && node scripts/release/prepare-desktop-app.js",
    "desktop:pack": "npm run build && npm run desktop:stage && electron-builder --projectDir .desktop-build/desktop-app --dir",
    "desktop:dist:mac": "npm run build && npm run desktop:stage && electron-builder --projectDir .desktop-build/desktop-app --mac dir && node scripts/release/build-signed-mac-dmg.js",
    "desktop:dist:mac:signed": "node scripts/release/require-signing-identity.js && npm run build && npm run desktop:stage && electron-builder --projectDir .desktop-build/desktop-app --mac dir && node scripts/release/build-signed-mac-dmg.js",
    "desktop:notarize:mac": "bash scripts/release/notarize-mac.sh",
    "desktop:dist:win": "npm run build && npm run desktop:stage && electron-builder --projectDir .desktop-build/desktop-app --win nsis",
    "server:bundle": "npm run build && node scripts/release/build-server-bundle.js",
    "desktop:icon:mac": "node electron/scripts/generate-macos-icon.js",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "prebuild:server": "node -e \"require('node:fs').rmSync('dist-server', { recursive: true, force: true })\"",
    "build:server": "tsc -p server/tsconfig.json && tsc-alias -p server/tsconfig.json",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p server/tsconfig.json",
    "test": "npm run test:desktop && npm run test:client && npm run test:server",
    "test:desktop": "node --test electron/*.test.js",
    "test:clean-device": "node scripts/test-clean-device.mjs",
    "test:client": "node scripts/test-client.mjs",
    "test:server": "node scripts/test-server.mjs",
    "lint": "eslint src/ server/ electron/ scripts/ --max-warnings 0",
    "lint:fix": "eslint src/ server/ electron/ scripts/ --fix",
    "start": "npm run build && npm run server",
    "release": "npm run desktop:dist:mac:signed && npm run desktop:notarize:mac",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/fix-node-pty.js",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.leoyuan.leocodebox",
    "productName": "leocodebox",
    "asar": false,
    "artifactName": "leocodebox-${version}-${os}-${arch}.${ext}",
    "electronVersion": "43.1.0",
    "directories": {
      "output": "release/desktop"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "afterPack": "scripts/release/after-pack.cjs",
    "files": [
      "electron/",
      "public/",
      "dist/",
      "dist-server/",
      "shared/",
      "server/",
      "package.json",
      "README.md",
      "LICENSE",
      "NOTICE",
      "!**/node_modules/@anthropic-ai/claude-agent-sdk-{darwin,linux,win32}-*/**",
      "!**/node_modules/@openai/codex-{darwin,linux,win32}-*/**",
      "!**/node_modules/playwright-core/.local-browsers/chromium-*/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "electron/assets/logo-macos.icns",
      "identity": null,
      "hardenedRuntime": false,
      "notarize": false,
      "target": [
        "dmg"
      ],
      "extendInfo": {
        "CFBundleName": "leocodebox",
        "CFBundleDisplayName": "leocodebox",
        "NSHumanReadableCopyright": "Copyright (c) 2026 leocodebox contributors. Third-party notices are included in NOTICE."
      }
    },
    "win": {
      "icon": "electron/assets/logo-windows.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "electron/assets/logo-windows.ico",
      "uninstallerIcon": "electron/assets/logo-windows.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "leoyb1010",
        "repo": "leocodebox",
        "private": true
      }
    ]
  },
  "keywords": [
    "claude code",
    "claude-code",
    "codex",
    "cursor",
    "cursor-cli",
    "anthropic",
    "openai",
    "google",
    "coding-agent",
    "web-ui",
    "ui",
    "mobile IDE"
  ],
  "author": "leocodebox maintainers",
  "license": "AGPL-3.0-or-later",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.165",
    "@iarna/toml": "^2.2.5",
    "@octokit/rest": "^22.0.0",
    "@openai/codex-sdk": "^0.144.0",
    "@vscode/ripgrep": "^1.17.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "cross-spawn": "^7.0.3",
    "electron-updater": "^6.8.9",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "i18next": "^25.7.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "mime-types": "^3.0.1",
    "multer": "^2.0.1",
    "node-pty": "^1.2.0-beta.12",
    "playwright": "1.61.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.1.2",
    "react-i18next": "^16.5.3",
    "react-router-dom": "^6.8.1",
    "tailwind-merge": "^3.3.1",
    "undici": "^7.28.0",
    "web-push": "^3.6.7",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.9",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.1",
    "@codemirror/lang-markdown": "^6.3.3",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/merge": "^6.11.1",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.39.3",
    "@release-it/conventional-changelog": "^10.0.5",
    "@replit/codemirror-minimap": "^0.5.2",
    "@tailwindcss/typography": "^0.5.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cross-spawn": "^6.0.6",
    "@types/express": "^4.17.25",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.19.7",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/react-test-renderer": "^18.3.1",
    "@types/ws": "^8.18.1",
    "@uiw/react-codemirror": "^4.23.13",
    "@vitejs/plugin-react": "^4.6.0",
    "@xterm/addon-clipboard": "^0.1.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "auto-changelog": "^2.5.0",
    "autoprefixer": "^10.4.16",
    "cmdk": "^1.1.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "dompurify": "^3.4.7",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.3",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "fuse.js": "^7.0.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "katex": "^0.16.25",
    "lint-staged": "^16.3.2",
    "lucide-react": "^0.515.0",
    "node-gyp": "^10.0.0",
    "postcss": "^8.4.32",
    "react-dropzone": "^14.2.3",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-test-renderer": "^18.3.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "release-it": "^19.0.5",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.2",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.0.4"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": "eslint --max-warnings 0",
    "server/**/*.{js,ts}": "eslint --max-warnings 0 --no-warn-ignored",
    "electron/**/*.js": "eslint --max-warnings 0",
    "scripts/**/*.{js,mjs,cjs}": "eslint --max-warnings 0"
  },
  "engines": {
    "node": ">=22"
  }
}
